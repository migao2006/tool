{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "files": {
    "includes": [
      "app.js",
      "src/**/*.js",
      ".github/scripts/**/*.mjs",
      "tests/e2e/**/*.js",
      "tests/e2e/**/*.mjs",
      "!src/vendor/**"
    ]
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noConstAssign": "error",
        "noUnreachable": "error",
        "noUndeclaredVariables": "error"
      },
      "suspicious": {
        "noDuplicateObjectKeys": "error"
      }
    }
  }
}
