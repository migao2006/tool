# Public Supabase project settings
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# One-time administrator provisioning only. Never upload a real value.
SUPABASE_SERVICE_ROLE_KEY=SET_LOCALLY_AND_NEVER_COMMIT
TWSS_ADMIN_USERNAME=Migao
TWSS_ADMIN_EMAIL=migao@admin.twss.local
TWSS_ADMIN_PASSWORD=SET_AT_LEAST_6_CHARACTERS

# v20 optional server-only integrations. Never expose these in browser code.
ALPHA_VANTAGE_API_KEY=SET_IN_VERCEL_OR_SUPABASE_SECRETS
FINNHUB_API_KEY=SET_IN_VERCEL_OR_SUPABASE_SECRETS
TWSS_V20_INTERNAL_KEY=GENERATE_A_LONG_RANDOM_SERVER_ONLY_VALUE
