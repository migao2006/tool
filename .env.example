# Server-side and GitHub Actions only. Never expose these values in browser code.
FINMIND_TOKEN=
FUGLE_API_KEY=
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Optional server-side runtime settings. Defaults are enforced in code.
API_HTTP_TIMEOUT_SECONDS=
HISTORICAL_BACKFILL_STORAGE_TARGET=
HISTORICAL_BACKFILL_MAX_ARCHIVE_OBJECTS_PER_RUN=
HISTORICAL_BACKFILL_MAX_ARCHIVE_OBJECT_BYTES=
HISTORICAL_BACKFILL_SEED_COMMON_TASKS=
HISTORICAL_BACKFILL_REFRESH_HOME_STATUS=
HISTORICAL_SUPPLEMENTAL_ALLOWED_DATASETS=
FUGLE_ADJUSTED_BACKFILL_ENABLED=
FUGLE_ADJUSTED_REQUEST_BUDGET_PER_RUN=
FUGLE_ADJUSTED_PACING_SECONDS=
FUGLE_ADJUSTED_RETRY_AFTER_SECONDS=

# Prediction Edge Function. Server-side only.
PREDICTION_ALLOWED_ORIGINS=
# Conservative wall-clock fallback used only when verified calendar coverage is unavailable.
# Default: 72
PREDICTION_STALE_AFTER_HOURS=
# Taipei hour (0-23) after which today must have a verified calendar observation.
# Default: 17
PREDICTION_CALENDAR_READY_HOUR_TAIPEI=
# Consecutive verified calendar days required before calendar-based freshness is trusted.
# Range: 14-62. Default: 45
PREDICTION_CALENDAR_LOOKBACK_DAYS=
# Default: 4000
PREDICTION_DATABASE_TIMEOUT_MS=
# Default: 10000
PREDICTION_REQUEST_TIMEOUT_MS=
# rpc: fail closed if the RPC is missing. legacy: emergency rollback only.
# Default: rpc
PREDICTION_SNAPSHOT_READ_MODE=
# Default: false
PREDICTION_RATE_LIMIT_ENABLED=
# Default: 30
PREDICTION_RATE_LIMIT_REQUESTS=
# Default: 60
PREDICTION_RATE_LIMIT_WINDOW_SECONDS=
# Must be a platform-overwritten address header, not an arbitrary browser header.
# Example trusted proxy header: CF-Connecting-IP
PREDICTION_RATE_LIMIT_CLIENT_IP_HEADER=
# Dedicated random secret, at least 32 characters. Required only when rate limiting is enabled.
PREDICTION_RATE_LIMIT_KEY_SECRET=
